# Copy this file to .env and fill in your project values.
# Never commit .env — it is already listed in .gitignore.

# ── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API

# Your project's REST/Auth base URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key — safe to ship in client bundles; RLS restricts data access
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Stripe ───────────────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API keys
# Use the PUBLISHABLE key (pk_live_... or pk_test_...) in the app
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# The following are set in Supabase Edge Function Secrets (NOT in .env):
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# PLATFORM_FEE_PERCENT=4
# APP_SCHEME=trainerhub
