{
  "expo": {
    "name": "TrainerHub",
    "slug": "trainerhub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trainerhub",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.trainerhub.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "TrainerHub sends you reminders before your training sessions.",
        "NSCameraUsageDescription": "TrainerHub uses the camera to scan payment cards when setting up Stripe payouts.",
        "NSPhotoLibraryAddUsageDescription": "TrainerHub saves your shareable trainer card to your photo library when you tap Save.",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "mailto",
          "tel"
        ]
      }
    },
    "android": {
      "package": "com.trainerhub.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#111111",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#111111"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#111111",
          "defaultChannel": "default"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TrainerHub uses your location to suggest nearby trainers.",
          "locationWhenInUsePermission": "TrainerHub uses your location to suggest nearby trainers."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "TrainerHub adds your sessions to your device calendar so you never miss one."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.trainerhub.app",
          "enableGooglePay": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "c9b45aab-bef9-4dc2-93df-201819a4fc1a"
      },
      "router": {}
    },
    "owner": "chrismarvel1"
  }
}
