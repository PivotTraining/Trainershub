{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo (all platforms)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 8081
    },
    {
      "name": "Expo iOS",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "ios"],
      "port": 8081
    },
    {
      "name": "Expo Android",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "android"],
      "port": 8081
    },
    {
      "name": "Expo Web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "8082"],
      "port": 8082
    },
    {
      "name": "Screen Preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "8083", "."],
      "port": 8083
    }
  ]
}
